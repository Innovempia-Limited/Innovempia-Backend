generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STUDENT
}

enum CourseType {
  TRACK
  SPECIFIC_LANGUAGE
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  COMPLETED
}

enum EnrollmentStatus {
  ACTIVE
  SUSPENDED
  COMPLETED
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  password          String
  firstName         String
  lastName          String
  phone             String?
  role              UserRole @default(STUDENT)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  enrollments       Enrollment[]
  notifications     Notification[]
  otps              Otp[]

  @@map("users")
}

model MentorshipCourse {
  id                String   @id @default(uuid())
  title             String
  type              CourseType
  description       String   @default("")
  imageUrl          String?
  videoUrl          String?
  requirements      String   @default("")
  instructorName    String
  instructorBio     String   @default("")
  instructorImage   String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subCategories     CourseSubCategory[]
  enrollments       Enrollment[]
  dayContents       DayContent[]

  @@map("mentorship_courses")
}

model CourseSubCategory {
  id                String   @id @default(uuid())
  name              String
  order             Int
  courseId          String
  course            MentorshipCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  enrollments       Enrollment[]
  dayContents       DayContent[]

  @@map("course_sub_categories")
}

model Enrollment {
  id                  String           @id @default(uuid())
  userId              String
  courseId            String
  currentSubCategoryId String?
  currentDay          Int              @default(1)
  level               Level            @default(BEGINNER)
  status              EnrollmentStatus @default(ACTIVE)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course              MentorshipCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  currentSubCategory  CourseSubCategory? @relation(fields: [currentSubCategoryId], references: [id])

  @@unique([userId, courseId])
  @@map("enrollments")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Otp {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [email], references: [email], onDelete: Cascade)

  @@map("otps")
}

model DayContent {
  id                  String   @id @default(uuid())
  courseId            String
  course              MentorshipCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subCategoryId       String?
  subCategory         CourseSubCategory? @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)
  level               Level    @default(BEGINNER)
  dayNumber           Int
  materialText        String   @default("")
  materialFileUrl     String?
  projectDescription  String   @default("")
  projectRequirements String   @default("")
  submissionMethod    String   @default("GITHUB_LINK") // GITHUB_LINK, PASTED_CODE, FILE_UPLOAD, MIXED
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([courseId, subCategoryId, level, dayNumber])
  @@map("day_contents")
}